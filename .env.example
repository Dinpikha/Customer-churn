# ============================================================
# Environment Variables — copy this to .env and fill in values
# ============================================================

# Neon PostgreSQL connection string
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/churndb?sslmode=require

# Optional: separate credentials
DB_HOST=ep-xxxx.us-east-2.aws.neon.tech
DB_PORT=5432
DB_NAME=churndb
DB_USER=your_username
DB_PASSWORD=your_password
